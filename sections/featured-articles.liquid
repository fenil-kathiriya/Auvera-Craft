{%- liquid

  assign image_size = section.settings.image_size
  assign enable_btn_blog = section.settings.enable_btn_blog
  assign enable_btn_line = section.settings.enable_btn_line
  assign enable_date = section.settings.enable_date
  assign enable_tag = section.settings.enable_tag
  assign enable_comment = section.settings.enable_comment
  assign enable_short = section.settings.enable_short
  assign text_color = section.settings.title_color
  assign style_btn = section.settings.style_btn
  
  assign show_slider = false
  if show_slider
    assign col_grid = "col"
  else
    case section.settings.show
      when 1
        assign col_grid = "col-12"
      when 2
        assign col_grid = "col-md-6 col-12"
      when 3
        assign col_grid = "col-lg-4 col-md-6 col-12"
      when 4
        assign col_grid = "col-lg-3 col-md-6 col-12"
      when 5
        assign col_grid = "col-lg-2-5 col-md-4 col-6"
      when 6
        assign col_grid = "col-lg-2 col-md-4 col-6"
      else
        assign col_grid = "col-lg-4 col-md-6 col-12"
    endcase
  endif

-%}
<style>
  .customstyle{{ section.id }}{
    {% if text_color != 'transparent' and text_color != 'rgba(0,0,0,0)' %}
      --g-font-color-subtop: {{ text_color }};
      --g-color-heading :  {{ text_color }};
      --color-body-text : {{ text_color }};
      --color-body-text-rgb: {{ text_color.red }}, {{ text_color.green }},  {{ text_color.blue }} ;
      --g-color-heading-rgb: {{ text_color.red }}, {{ text_color.green }},  {{ text_color.blue }} ;
    {% endif %}
  }
  .blog-section{{ section.id }}{
    position: relative;
    z-index: {{ section.settings.zindex }};
  }
  
  /* Image sizing */
  .article__photo-wrapper {
    position: relative;
    display: block;
    width: 100%;
  }
  .article__photo-wrapper.auto,
  .article__photo-wrapper { padding-top: 75% !important; overflow: hidden; }
  .article__photo-wrapper.portrait{ padding-top: 120% !important; overflow: hidden; }
  .article__photo-wrapper.square{ padding-top: 100% !important; overflow: hidden; }
  .article__photo-wrapper.landscape{ padding-top: 75% !important; overflow: hidden; }
  .article__photo-wrapper.wide{ padding-top: 56% !important; overflow: hidden; }
  
  .article__photo-wrapper.portrait img,
  .article__photo-wrapper.square img, 
  .article__photo-wrapper.landscape img,
  .article__photo-wrapper.wide img{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .bloglist-wrapper .blog__item{
    margin-bottom: 0 !important;
    padding-bottom: 0px !important;
  }

  @media(max-width:749px){
    .blog__item--3 .article__photo-wrapper{
      padding-top: 100% !important;
    }
  }

  /* --- NEW ALIGNMENT & TEXT WRAP FIXES --- */

  /* 1. Force Slick Carousel to make all slides equal height */
  .bloglist-slider .slick-track {
    display: flex !important;
  }
  .bloglist-slider .slick-slide {
    height: auto !important;
    display: flex !important;
    flex-direction: column;
  }
  .bloglist-slider .slick-slide > div {
    height: 100%;
    width: 100%;
    display: flex;
  }

  /* 2. Format the individual blog items */
  .bloglist-item {
    height: 100%;
    width: 100%;
    display: flex;
  }

  .bloglist-item .blog__item {
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    background: transparent;
    max-width: 100%; 
    overflow: hidden; 
  }

  .bloglist-item .content-block__image {
    position: relative;
    margin-bottom: 0;
    overflow: hidden;
    width: 100%;
  }

  /* 3. Turn the text content into a flex column and push the button down */
  .bloglist-item .blog__content {
    text-align: left;
    padding: 20px 10px;
    flex-grow: 1;
    position: relative;
    z-index: 2;
    background: transparent;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .bloglist-item .blog__content > *:last-child {
    margin-top: auto !important;
    align-self: flex-start; 
  }

  /* 4. Stop text from bleeding into the next slide */
  .bloglist-item .blog__content p,
  .bloglist-item .blog__content div,
  .bloglist-item .blog__content span {
    white-space: normal !important;
    word-break: break-word !important;
    overflow-wrap: break-word !important;
    max-width: 100%;
  }

  .bloglist-item .blog__title-link {
    white-space: normal !important;
    word-break: break-word !important;
    display: block;
  }

  /* --- Custom Button Styles matching the simple bold design --- */
  .customstyle{{ section.id }} .btn,
  .customstyle{{ section.id }} .button {
    background-color: #D4B27E !important; /* Auvera Gold */
    color: #ffffff !important;
    border: 3px solid #1E1E1E !important; /* Auvera Charcoal */
    border-radius: 999px !important; /* Pill shape */
    box-shadow: -4px 4px 0px 0px #1E1E1E !important; /* Hard bottom-left shadow */
    
    /* Simple Bold Font Updates */
    font-family: Arial, Helvetica, sans-serif !important; /* Clean, standard font */
    font-weight: 900 !important; /* Extra bold */
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    font-size: 16px !important; 
    
    padding: 14px 40px !important;
    transition: all 0.15s ease !important;
    
    /* White text with THIN charcoal outline */
    -webkit-text-fill-color: #ffffff !important;
    -webkit-text-stroke: 0px #1E1E1E !important; /* Thin 1px border */
    text-shadow: none !important;
    display: inline-block !important; /* Ensures button shape holds */
  }

  .customstyle{{ section.id }} .btn:hover,
  .customstyle{{ section.id }} .button:hover {
    background-color: #C8A46A !important; /* Auvera Gold Hover */
    transform: translate(-3px, 3px) !important;
    box-shadow: -3px 3px 0px 0px #1E1E1E !important; /* Shadow shrinks on hover */
    color: #ffffff !important;
  }

  .customstyle{{ section.id }} .btn:active,
  .customstyle{{ section.id }} .button:active {
    transform: translate(-6px, 6px) !important;
    box-shadow: 0px 0px 0px 0px #1E1E1E !important; /* Button pushes in completely on click */
  }

  /* Fix icon alignment and outline inside the button */
  .customstyle{{ section.id }} .btn svg,
  .customstyle{{ section.id }} .btn i,
  .customstyle{{ section.id }} .btn .d-inline-block {
    -webkit-text-stroke: 0px !important; /* Removes outline from icon if present */
    text-shadow: none !important;
  }

  /* Custom clean card overrides matching blog template */
  .customstyle{{ section.id }} .blog__item--1 .content-block__image {
    margin-bottom: 15px !important;
  }
  .customstyle{{ section.id }} .blog__item--1 .blog__title-link {
    margin-bottom: 0 !important;
  }
  .customstyle{{ section.id }} .blog__item--1 .blog__title-link a {
    font-size: 1.05rem;
    font-weight: 700;
    color: #111111;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .customstyle{{ section.id }} .blog__item--1 .blog__title-link a:hover {
    color: var(--g-color-primary, #007bff);
  }
  .customstyle{{ section.id }} .blog__item--1 .article__photo-wrapper {
    border-radius: 6px !important;
    overflow: hidden !important;
  }
  .customstyle{{ section.id }} .blog__item--1 .article__photo-wrapper img {
    transition: transform 0.3s ease;
  }
  .customstyle{{ section.id }} .blog__item--1:hover .article__photo-wrapper img {
    transform: scale(1.03);
  }

  /* Grid layout overrides when slider is disabled */
  .customstyle{{ section.id }} .bloglist-item {
    margin-bottom: 30px;
  }

/* 3 Column Blog Grid */
#Bloglist-{{ section.id }}{
 display:flex !important;
 flex-wrap:wrap !important;
}
#Bloglist-{{ section.id }} .bloglist-item{
 width:33.3333%;
 flex:0 0 33.3333%;
 padding:15px;
}
@media (max-width:991px){
 #Bloglist-{{ section.id }} .bloglist-item{width:50%;flex:0 0 50%;}
}
@media (max-width:767px){
 #Bloglist-{{ section.id }} .bloglist-item{width:100%;flex:0 0 100%;}
}

</style>

<div class="customstyle{{ section.id }} blog-section{{section.id}}" data-aos="{{ section.settings.animation }}">
  {%- render 'style-section' -%}
<div class="{{ section.settings.setwidth }}">
  <div class="section-block">
    {%- render 'section-heading' -%}
    <div class="bloglist-wrapper {% if show_slider %}dots-negative{% endif %}" data-aos="{{ section.settings.animation }}">
      <div class="row {% if show_slider %}bloglist-slider{% endif %}" id="Bloglist-{{ section.id }}"
           {% if show_slider %}
           data-rows="{{ section.settings.rows }}"
           data-slidesToShow="{{ section.settings.show }}"
           data-arrows="{{ section.settings.arrows }}"
           data-dots="{{ section.settings.dots }}" 
           data-draggable="{{ section.settings.draggable }}" 
           data-infinite="{{ section.settings.infinite }}" 
           data-section-id="{{ section.id }}" 
           data-section-type="slickCarousels"
           {% endif %}>
        {%- assign blog = blogs[section.settings.blog] -%}
        {%- if blog != blank -%}
{% paginate blog.articles by 12 %}
{%- for article in blog.articles -%}
        <div class="bloglist-item {{ col_grid }}">
          <div data-aos="{{ section.settings.animation }}"  data-aos-delay="{{ forloop.index | times: 100 }}" style="height: 100%; display: flex;">
            {%- liquid
              case section.settings.item_style
              when 'blog-1'
                render 'blog-grid-1', article : article, image_size : image_size, enable_btn_blog : enable_btn_blog, enable_btn_line: enable_btn_line, enable_date : enable_date, enable_tag : enable_tag, enable_comment: enable_comment, enable_short : enable_short, style_btn: style_btn, text_color: text_color
              when 'blog-3'
                render 'blog-grid-3', article : article, image_size : image_size, enable_btn_blog : enable_btn_blog, enable_btn_line: enable_btn_line, enable_date : enable_date, enable_tag : enable_tag, enable_comment: enable_comment, enable_short : enable_short
              when 'blog-5'
                render 'blog-grid-5', article : article, image_size : image_size, enable_btn_blog : enable_btn_blog, enable_btn_line: enable_btn_line, enable_date : enable_date, enable_tag : enable_tag, enable_comment: enable_comment, enable_short : enable_short, style_btn: style_btn
              when 'blog-6'
                render 'blog-grid-6', article : article, image_size : image_size, enable_btn_blog : enable_btn_blog, enable_btn_line: enable_btn_line, enable_date : enable_date, enable_tag : enable_tag, enable_comment: enable_comment, enable_short : enable_short, enable_short, style_btn: style_btn
              when 'blog-7'
                render 'blog-grid-7', article : article, image_size : image_size, enable_btn_blog : enable_btn_blog, enable_btn_line: enable_btn_line, enable_date : enable_date, enable_tag : enable_tag, enable_comment: enable_comment, enable_short : enable_short, enable_short, style_btn: style_btn
              else
                render 'blog-grid-blank'
              endcase
            -%}
          </div>
        </div>

        <div class="view-all-blog-btn">
  <a href="/blogs/news">View All</a>
</div>

        {%- endfor -%}
{% if paginate.pages > 1 %}<div class="blog-pagination text-center mt-5">{{ paginate | default_pagination }}</div>{% endif %}
{% endpaginate %}
        {%- else -%}
        {%- for i in (1..limit) -%}
        <div class="bloglist-item {{ col_grid }}">
          <div data-aos="{{ section.settings.animation }}"  data-aos-delay="{{ forloop.index | times: 100 }}" style="height: 100%; display: flex;">
          {%- render 'blog-grid-blank' -%}
        </div>
        </div>
        {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
</div>

