<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&display=swap');

  /* ============================================================================
    Base Neo-Brutalist Button Style (Auvera style with Barlow Condensed)
  ============================================================================== */
  .customstyle{{ section.id }} .btn-pill-shadow {
    background-color: #C4A77D !important; /* Tan background */
    color: #FFFFFF !important; /* White text */
    font-family: 'Barlow Condensed', sans-serif !important; 
    border-radius: 50px !important; /* Pill shape */
    padding: 14px 48px !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    font-size: 18px !important; 
    font-weight: 700 !important; /* Bold weight for Barlow Condensed */
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: all 0.15s ease-in-out !important;
    line-height: 1.2 !important;
    border: 3px solid #111111 !important; /* Thick dark border */
    box-shadow: -4px 4px 0px 0px #111111 !important; /* Solid offset shadow */
    -webkit-text-stroke: 0px #111111 !important; /* Reduced thinner black text outline */
    margin-bottom: 12px; /* Adding margin so the shadow doesn't get cut off */
    margin-left: 12px;
  }

  .customstyle{{ section.id }} .btn-pill-shadow:hover {
    background-color: #B5986F !important; /* Slightly darker tan on hover */
    transform: translate(-4px, 4px) !important; /* Push down effect */
    box-shadow: -4px 4px 0px 0px #111111 !important; /* Shrink shadow */
  }

  .customstyle{{ section.id }} .btn-pill-shadow:active {
    transform: translate(-8px, 8px) !important; /* Fully pressed */
    box-shadow: 0px 0px 0px 0px #111111 !important;
  }

  /* ─── Mobile Adjustments for 2-Column Layout ────────────── */
  @media (max-width: 767px) {
    .customstyle{{ section.id }} .btn-pill-shadow {
      padding: 10px 20px !important; /* Smaller padding so it fits in half-width */
      font-size: 14px !important;
      margin-left: 6px !important;
      box-shadow: -4px 4px 0px 0px #111111 !important; /* Smaller shadow */
    }
    .customstyle{{ section.id }} .btn-pill-shadow:hover {
      transform: translate(-2px, 2px) !important; 
      box-shadow: -2px 2px 0px 0px #111111 !important;
    }
    .customstyle{{ section.id }} .banner-text--block figcaption {
      padding: 1rem 0.5rem !important; /* Slightly tighter padding inside the card */
    }
    /* Scale down headings slightly for mobile half-width */
    .customstyle{{ section.id }} .banner-text--block h3 {
      font-size: 18px !important; 
    }
    .customstyle{{ section.id }} .banner-text--block p {
      font-size: 13px !important;
    }
  }
</style>

<div class="customstyle{{ section.id }} banner-theme-text" data-aos="{{ section.settings.animation }}" >
  {%- render 'style-section' -%}
<div class="{{ section.settings.setwidth }}">
  <div class="section-block">
    {%- render 'section-heading' -%}
    <div class="row banner-gap {% if section.settings.no_gutter %}no-gutters{% endif %}">
      {%- for block in section.blocks -%}
      <style>
       .banner-{{ block.id }}{
         border:1px solid {{ block.settings.border_banner }};
         background-color:{{ block.settings.bg_banner }};
         position:relative;
       }
      </style>
      
      <div class="col-6 col-md-{{ block.settings.width }}" {{ block.shopify_attributes }} data-aos="{{ section.settings.animation }}" data-aos-delay="{{ forloop.index | times: 100 }}">
      
      <div class="banner-{{ block.id }} banner-text--block" style="padding:{{ block.settings.paddingblock }}">
        <figure class="position-relative m-0 hv-image-saturate text-{{ block.settings.text_align }} {% if section.settings.no_gutter %}m-0{% endif %} d-flex {{ block.settings.reverse }}">
          {%- if block.settings.image != blank -%}

          {%- if block.settings.button_link != blank -%}<a href="{{block.settings.button_link}}"> {%- endif -%}
          <div class="image-content__image-container overflow-hidden">
            <div class="image-content__image-wrapper" style="padding-top:{{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;">
                <img
                  srcset="
                    {%- if block.settings.image.width >= 165 -%}{{ block.settings.image | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if block.settings.image.width >= 360 -%}{{ block.settings.image | image_url: width: 360 }} 360w,{%- endif -%}
                    {%- if block.settings.image.width >= 533 -%}{{ block.settings.image | image_url: width: 533 }} 533w,{%- endif -%}
                    {%- if block.settings.image.width >= 720 -%}{{ block.settings.image | image_url: width: 720 }} 720w,{%- endif -%}
                    {%- if block.settings.image.width >= 940 -%}{{ block.settings.image | image_url: width: 940 }} 940w,{%- endif -%}
                    {%- if block.settings.image.width >= 1066 -%}{{ block.settings.image | image_url: width: 1066 }} 1066w,{%- endif -%}
                    {{ block.settings.image | image_url }} {{ block.settings.image.width }}w
                  "
                  src="{{ block.settings.image | image_url: width: 1066 }}"
                  sizes="(min-width: {{ settings.container }}px) {{ settings.container | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  alt="{{ block.settings.image.alt | escape }}"
                  class="image-content__image scale-in lazyload "
                  data-sizes="auto"
                  data-aspectratio="{{ block.settings.image.aspect_ratio }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
                </div>
              </div>
            {%- if block.settings.button_link != blank -%}</a> {%- endif -%}
         
          {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <figcaption class="figcaption--{{ block.id }} py-4">
            {%- if block.settings.description -%}
            {{ block.settings.description }}
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
            <a href="{{ block.settings.button_link }}" class="btn {{ block.settings.style_btn }}">
             {{ block.settings.button_text }}
            </a>
            {%- endif -%}
          </figcaption>   
        </figure>
        </div>
      </div>
      {%- endfor -%}
    </div>
  </div>
</div>
</div>
  
