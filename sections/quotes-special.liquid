      "default": "REVIEWS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What Our Customers Say"
    },
    {
      "type": "textarea",
      "id": "des",
      "label": "Description",
      "default": "Real stories. Real sparkle."
    },
    {
      "type": "text",
      "id": "more_love_title",
      "label": "Small Reviews Heading",
      "default": "More Love"
    },
    {
      "type": "color",
      "id": "color_rate",
      "label": "Accent Color (Stars/Lines)",
      "default": "#d4af37"
    },
    {
      "type": "color",
      "id": "color_rated",
      "label": "Color Rated",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Size Image"
