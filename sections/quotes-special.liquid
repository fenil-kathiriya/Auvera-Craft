    },
    {
      "type": "checkbox",
      "id": "infinite",
      "label": "Infinite",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding "
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Padding Section Desktop",
      "default": "30px 0px"
    },
    {
      "type": "text",
      "id": "paddingmobile",
      "label": "Padding Section Mobile",
      "default": "20px 0px"
    },
    {
      "type": "header",
      "content": "Section Margin "
    },
    {
      "type": "text",
      "id": "marginsection",
      "label": "Margin Section",
      "default": "0px"
    },
    {
      "type": "text",
      "id": "marginmobile",
      "label": "Margin Mobile",
      "default": "0px"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Featured Quote",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Subheading",
          "default": "AMAZING"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Text",
          "default": "The ring is AMAZING. It's an eye catcher for everyone. Extremely well made and we love it."
        },
        {
          "type": "range",
          "id": "rate",
          "min": 0, "max": 5, "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Joseph M."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show Verified Buyer Badge",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Image"
        }
      ]
    },
    {
      "type": "small_quote",
      "name": "Small Quote (More Love)",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Subheading",
          "default": "AMAZING"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Text",
          "default": "Absolutely stunning! The detail and quality exceeded my expectations."
