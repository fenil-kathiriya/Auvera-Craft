{%- comment -%}
  Diamond Collection Slider (Auvera Style)
{%- endcomment -%}

<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=Barlow:wght@400;500;700&display=swap');

#diamond-section-{{ section.id }} {
  --bg: {{ section.settings.bg_color }};
  --text-dark: {{ section.settings.text_dark }};
  --text-mid: {{ section.settings.text_mid }};
  --accent: {{ section.settings.accent_color }};
  --item-w: 420px;
  --item-img: 340px;

  width: 100%;
  padding: {{ section.settings.padding_desktop }};
  background: var(--bg);
  position: relative;
  overflow: hidden;
  font-family: 'Barlow', sans-serif;
}

@media (max-width: 768px) {
  #diamond-section-{{ section.id }} {
    padding: {{ section.settings.padding_mobile }};
  }
}

#diamond-section-{{ section.id }} *, 
#diamond-section-{{ section.id }} *::before, 
#diamond-section-{{ section.id }} *::after { 
  box-sizing: border-box; 
}

/* ── Section heading ── */
#diamond-section-{{ section.id }} .section-head {
  text-align: center;
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}
#diamond-section-{{ section.id }} .section-head .eyebrow {
  font-family: 'Barlow', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 14px;
  display: block;
}
#diamond-section-{{ section.id }} .section-head h2 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(36px, 6vw, 64px);
  font-weight: 900;
  color: var(--text-dark);
  letter-spacing: 1px;
  text-transform: uppercase;
  line-height: 1.1;
  margin: 0;
}
#diamond-section-{{ section.id }} .section-head h2 em {
  font-style: normal;
  color: var(--accent);
}
#diamond-section-{{ section.id }} .section-head .rule {
  width: 40px;
  height: 2px;
  background: var(--accent);
  margin: 15px auto 0;
}

/* ── Viewport ── */
#diamond-section-{{ section.id }} .slider-viewport {
  width: 100%;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

/* left & right fade edges */
#diamond-section-{{ section.id }} .slider-viewport::before,
#diamond-section-{{ section.id }} .slider-viewport::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 180px;
  z-index: 20;
  pointer-events: none;
}
#diamond-section-{{ section.id }} .slider-viewport::before {
  left: 0;
  background: linear-gradient(to right, var(--bg) 0%, transparent 100%);
}
#diamond-section-{{ section.id }} .slider-viewport::after {
  right: 0;
  background: linear-gradient(to left, var(--bg) 0%, transparent 100%);
}

/* ── Track ── */
#diamond-section-{{ section.id }} .slider-track {
  display: flex;
  align-items: center;
  height: 480px;
  will-change: transform;
  transition: transform 0.72s cubic-bezier(0.4, 0, 0.2, 1);
  touch-action: pan-y;
}

/* ── Item ── */
#diamond-section-{{ section.id }} .diamond-item {
  width: var(--item-w);
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.38) translateY(20px);
  transition:
    opacity 0.72s cubic-bezier(0.4, 0, 0.2, 1),
    transform 0.72s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  z-index: 1;
  cursor: pointer;
}

#diamond-section-{{ section.id }} .diamond-item a {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}
#diamond-section-{{ section.id }} .diamond-item.is-active a { pointer-events: all; }

/* ── Image ── */
#diamond-section-{{ section.id }} .img-wrap {
  position: relative;
  width: var(--item-img);
  height: var(--item-img);
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(ellipse at center, #ffffff 30%, var(--bg) 75%);
  border-radius: 50%;
}

#diamond-section-{{ section.id }} .img-wrap::before {
  content: '';
  position: absolute;
  inset: -20px;
  border-radius: 50%;
  /* Using rgba equivalent of #D4B27E */
  background: radial-gradient(circle, rgba(212,178,126,0.15) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.72s ease;
}
#diamond-section-{{ section.id }} .diamond-item.is-active .img-wrap::before { opacity: 1; }

#diamond-section-{{ section.id }} .diamond-item img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  filter: drop-shadow(0 20px 40px rgba(30,30,30,0.07));
  transition: filter 0.72s ease;
  user-select: none;
  -webkit-user-drag: none;
}
#diamond-section-{{ section.id }} .diamond-item.is-active img {
  filter: drop-shadow(0 30px 60px rgba(30,30,30,0.15));
}

/* ── Info ── */
#diamond-section-{{ section.id }} .diamond-info {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.5s ease 0.18s, transform 0.5s ease 0.18s;
  margin-top: 6px;
  text-align: center;
  padding: 0 24px;
}
#diamond-section-{{ section.id }} .diamond-info .d-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 26px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-dark);
  margin-bottom: 4px;
}
#diamond-section-{{ section.id }} .diamond-info .d-desc {
  font-family: 'Barlow', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 1px;
  color: var(--text-mid);
  line-height: 1.5;
  text-transform: uppercase;
}
#diamond-section-{{ section.id }} .diamond-info .d-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  border-bottom: 2px solid var(--accent);
  padding-bottom: 2px;
  transition: gap 0.3s ease;
  text-decoration: none;
}
#diamond-section-{{ section.id }} .diamond-info .d-cta:hover { gap: 12px; }
#diamond-section-{{ section.id }} .diamond-info .d-cta svg { width: 14px; height: 10px; }

/* ── Visible states (one-by-one cascade) ── */
#diamond-section-{{ section.id }} .diamond-item.is-active {
  opacity: 1;
  transform: scale(1.3) translateY(0);
  z-index: 10;
}
#diamond-section-{{ section.id }} .diamond-item.is-active .diamond-info {
  opacity: 1;
  transform: translateY(0);
}

#diamond-section-{{ section.id }} .diamond-item.is-prev,
#diamond-section-{{ section.id }} .diamond-item.is-next {
  opacity: 0.72;
  transform: scale(0.68) translateY(0);
  transition-delay: 0.04s;
}

#diamond-section-{{ section.id }} .diamond-item.is-prev2,
#diamond-section-{{ section.id }} .diamond-item.is-next2 {
  opacity: 0.36;
  transform: scale(0.50) translateY(0);
  transition-delay: 0.09s;
}

/* ── Controls ── */
#diamond-section-{{ section.id }} .slider-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  margin-top: 10px;
  position: relative;
  z-index: 1;
}

#diamond-section-{{ section.id }} .arrow-btn {
  background: transparent;
  border: 2px solid var(--text-mid);
  cursor: pointer;
  width: 46px;
  height: 46px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  color: var(--text-dark);
  outline: none;
  flex-shrink: 0;
  padding: 0;
}
#diamond-section-{{ section.id }} .arrow-btn:hover {
  border-color: var(--text-dark);
  background: var(--text-dark);
  color: var(--bg);
}
#diamond-section-{{ section.id }} .arrow-btn svg { width: 16px; height: 10px; }

#diamond-section-{{ section.id }} .counter {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--text-mid);
  letter-spacing: 2px;
  min-width: 60px;
  text-align: center;
}
#diamond-section-{{ section.id }} .counter .cur { color: var(--text-dark); font-weight: 900; }

#diamond-section-{{ section.id }} .dots {
  display: flex;
  gap: 8px;
  align-items: center;
}
#diamond-section-{{ section.id }} .dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--text-mid);
  transition: all 0.4s ease;
  cursor: pointer;
  opacity: 0.5;
}
#diamond-section-{{ section.id }} .dot.active {
  background: var(--text-dark);
  width: 24px;
  border-radius: 60px;
  opacity: 1;
}

/* ── Responsive ── */
@media (max-width: 1100px) {
  #diamond-section-{{ section.id }} { --item-w: 340px; --item-img: 280px; }
  #diamond-section-{{ section.id }} .slider-track { height: 430px; }
}
@media (max-width: 768px) {
  #diamond-section-{{ section.id }} { --item-w: 260px; --item-img: 210px; }
  #diamond-section-{{ section.id }} .slider-track { height: 360px; }
  #diamond-section-{{ section.id }} .diamond-item.is-active { transform: scale(1.18) translateY(0); }
  #diamond-section-{{ section.id }} .diamond-info .d-name { font-size: 20px; }
}
@media (max-width: 480px) {
  #diamond-section-{{ section.id }} { --item-w: 200px; --item-img: 160px; }
  #diamond-section-{{ section.id }} .slider-track { height: 300px; }
  #diamond-section-{{ section.id }} .diamond-item.is-active { transform: scale(1.1) translateY(0); }
  #diamond-section-{{ section.id }} .diamond-info .d-name { font-size: 16px; letter-spacing: 1px; }
  #diamond-section-{{ section.id }} .diamond-info .d-desc { font-size: 10px; }
  #diamond-section-{{ section.id }} .section-head { margin-bottom: 8px; }
}
</style>

<section id="diamond-section-{{ section.id }}">

  <div class="section-head">
    {% if section.settings.eyebrow != blank %}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="rule"></div>
  </div>

  <div class="slider-viewport">
    <div class="slider-track" id="sliderTrack-{{ section.id }}">
      
      {% for block in section.blocks %}
      <div class="diamond-item" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link | default: '#' }}">
          <div class="img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" width="600" height="600" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% else %}
              <div style="width: 100%; height: 100%; display: flex; align-items:center; justify-content:center; opacity: 0.5;">
                 {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
          </div>
          <div class="diamond-info">
            <div class="d-name">{{ block.settings.title }}</div>
            <div class="d-desc">{{ block.settings.description }}</div>
            <span class="d-cta">{{ block.settings.cta_text }} <svg viewbox="0 0 18 8" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M0 4h16M12 1l4 3-4 3"></path></svg></span>
          </div>
        </a>
      </div>
      {% endfor %}

    </div>
  </div>

  <div class="slider-meta">
    <button class="arrow-btn" id="prevBtn-{{ section.id }}" aria-label="Previous">
      <svg viewbox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6H2M7 1L2 6l5 5"></path>
      </svg>
    </button>

    <div class="dots" id="dotsWrap-{{ section.id }}"></div>

    <div class="counter">
      <span class="cur" id="counterCur-{{ section.id }}">01</span> / <span id="counterTotal-{{ section.id }}">00</span>
    </div>

    <button class="arrow-btn" id="nextBtn-{{ section.id }}" aria-label="Next">
      <svg viewbox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M0 6h16M11 1l5 5-5 5"></path>
      </svg>
    </button>
  </div>

</section>

<script>
function initDiamondSlider_{{ section.id | replace: '-', '_' }}() {
  const sectionWrap = document.getElementById('diamond-section-{{ section.id }}');
  if (!sectionWrap) return;

  const track    = document.getElementById('sliderTrack-{{ section.id }}');
  const prevBtn  = document.getElementById('prevBtn-{{ section.id }}');
  const nextBtn  = document.getElementById('nextBtn-{{ section.id }}');
  const dotsWrap = document.getElementById('dotsWrap-{{ section.id }}');
  const counterCur   = document.getElementById('counterCur-{{ section.id }}');
  const counterTotal = document.getElementById('counterTotal-{{ section.id }}');

  track.querySelectorAll('.clone').forEach(c => c.remove());

  const originals = Array.from(track.querySelectorAll('.diamond-item:not(.clone)'));
  const total = originals.length;
  if (total === 0) return;

  let current = 0;
  let isAnimating = false;

  function itemWidth() {
    const sw = window.innerWidth;
    if (sw <= 480) return 200;
    if (sw <= 768) return 260;
    if (sw <= 1100) return 340;
    return 420;
  }

  function buildClones() {
    const before = originals.map(el => { const c = el.cloneNode(true); c.classList.add('clone'); return c; });
    const after  = originals.map(el => { const c = el.cloneNode(true); c.classList.add('clone'); return c; });
    before.reverse().forEach(c => track.insertBefore(c, originals[0]));
    after.forEach(c => track.appendChild(c));
  }

  function allItems() {
    return Array.from(track.querySelectorAll('.diamond-item'));
  }

  function setTrack(animate) {
    const w  = itemWidth();
    const vw = track.parentElement.offsetWidth;
    const cx = vw / 2 - w / 2;
    const idx = total + current;
    track.style.transition = animate ? 'transform 0.72s cubic-bezier(0.4,0,0.2,1)' : 'none';
    track.style.transform = `translateX(${cx - idx * w}px)`;
  }

  function setClasses() {
    const items = allItems();
    const base  = total + current;
    items.forEach((el, i) => {
      el.classList.remove('is-active','is-prev','is-next','is-prev2','is-next2');
      const d = i - base;
      if      (d ===  0) el.classList.add('is-active');
      else if (d === -1) el.classList.add('is-prev');
      else if (d ===  1) el.classList.add('is-next');
      else if (d === -2) el.classList.add('is-prev2');
      else if (d ===  2) el.classList.add('is-next2');
    });
  }

  function buildDots() {
    dotsWrap.innerHTML = '';
    for (let i = 0; i < total; i++) {
      const d = document.createElement('div');
      d.className = 'dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i));
      dotsWrap.appendChild(d);
    }
    counterTotal.textContent = String(total).padStart(2, '0');
  }

  function updateUI() {
    const norm = ((current % total) + total) % total;
    Array.from(dotsWrap.children).forEach((d, i) => d.classList.toggle('active', i === norm));
    counterCur.textContent = String(norm + 1).padStart(2, '0');
  }

  function goTo(idx) {
    if (isAnimating) return;
    current = idx;
    setTrack(true);
    setClasses();
    updateUI();
  }

  function slide(dir) {
    if (isAnimating) return;
    isAnimating = true;
    current += dir;
    setTrack(true);
    setClasses();
    updateUI();

    setTimeout(() => {
      if (current >= total || current < 0) {
        current = ((current % total) + total) % total;
        setTrack(false);
        setClasses();
        updateUI();
      }
      isAnimating = false;
    }, 720);
  }

  const newPrevBtn = prevBtn.cloneNode(true);
  const newNextBtn = nextBtn.cloneNode(true);
  prevBtn.parentNode.replaceChild(newPrevBtn, prevBtn);
  nextBtn.parentNode.replaceChild(newNextBtn, nextBtn);

  newPrevBtn.addEventListener('click', () => slide(-1));
  newNextBtn.addEventListener('click', () => slide(1));

  let tx = 0;
  track.parentElement.addEventListener('touchstart', e => tx = e.changedTouches[0].screenX, { passive: true });
  track.parentElement.addEventListener('touchend',   e => {
    const d = e.changedTouches[0].screenX - tx;
    if (Math.abs(d) > 30) slide(d < 0 ? 1 : -1);
  }, { passive: true });

  window.addEventListener('resize', () => setTrack(false));

  buildClones();
  buildDots();
  setTrack(false);
  setClasses();
  updateUI();
}

document.addEventListener('DOMContentLoaded', initDiamondSlider_{{ section.id | replace: '-', '_' }});
document.addEventListener('shopify:section:load', function(e) {
  if (e.detail.sectionId === '{{ section.id }}') {
    initDiamondSlider_{{ section.id | replace: '-', '_' }}();
  }
});
</script>

{% schema %}
{
  "name": "Diamond Slider (Auvera)",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF8F5"
    },
    {
      "type": "color",
      "id": "text_dark",
      "label": "Text Dark",
      "default": "#1E1E1E"
    },
    {
      "type": "color",
      "id": "text_mid",
      "label": "Text Mid",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#D4B27E"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Curated Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Your <em>Perfect</em> Diamond",
      "info": "Use <em> around words to apply the accent color."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "text",
      "id": "padding_desktop",
      "label": "Padding Desktop",
      "default": "40px 0 60px"
    },
    {
      "type": "text",
      "id": "padding_mobile",
      "label": "Padding Mobile",
      "default": "30px 0 40px"
    }
  ],
  "blocks": [
    {
      "type": "diamond",
      "name": "Diamond Shape",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Diamond Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Shape Name",
          "default": "Round"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Maximises brilliance & light return"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Button Text",
          "default": "Explore"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Diamond Slider (Auvera)",
      "blocks": [
        { "type": "diamond", "settings": { "title": "Round", "description": "Maximises brilliance & light return" } },
        { "type": "diamond", "settings": { "title": "Princess", "description": "Brilliance in a bold square form" } },
        { "type": "diamond", "settings": { "title": "Emerald", "description": "Elegant step cuts, modern appeal" } },
        { "type": "diamond", "settings": { "title": "Heart", "description": "The ultimate symbol of romance" } },
        { "type": "diamond", "settings": { "title": "Oval", "description": "Elongated brilliance, flatters the finger" } }
      ]
    }
  ]
}
