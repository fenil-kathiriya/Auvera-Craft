{%- style -%}
  .jewelry-gallery-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    width: 100%;
  }

  .jewelry-gallery-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .jewelry-gallery-heading {
    font-family: var(--font-heading-family), serif;
    font-weight: 300;
    letter-spacing: 2px;
    margin-bottom: 40px;
    font-size: 2.5rem;
    color: {{ section.settings.text_color }};
  }

  .jewelry-gallery-grid {
    display: grid;
    /* Auto-fits columns that are at least 300px wide */
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: {{ section.settings.grid_gap }}px;
  }

  .jewelry-gallery-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 4 / 5; /* Perfect portrait ratio for jewelry */
  }

  .jewelry-gallery-item img, 
  .jewelry-gallery-item svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .jewelry-gallery-item svg {
    background-color: #f4f4f4;
  }

  .jewelry-gallery-item:hover img {
    transform: scale(1.08);
  }

  .jewelry-gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3); /* Subtle dark overlay on hover */
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .jewelry-gallery-item:hover .jewelry-gallery-overlay {
    opacity: 1;
  }

  .jewelry-gallery-overlay h3 {
    margin: 0;
    color: #ffffff;
    font-family: var(--font-heading-family), serif;
    font-weight: 400;
    letter-spacing: 2px;
    font-size: 1.8rem;
    text-transform: uppercase;
    transform: translateY(15px);
    transition: transform 0.4s ease;
  }

  .jewelry-gallery-overlay p {
    margin: 10px 0 0;
    color: #ffffff;
    font-size: 1rem;
    letter-spacing: 1px;
    transform: translateY(15px);
    transition: transform 0.4s ease;
  }

  .jewelry-gallery-item:hover .jewelry-gallery-overlay h3,
  .jewelry-gallery-item:hover .jewelry-gallery-overlay p {
    transform: translateY(0);
  }

  /* Mobile adjustments */
  @media screen and (max-width: 768px) {
    .jewelry-gallery-grid {
      grid-template-columns: repeat(2, 1fr); /* 2 columns on mobile */
      gap: 10px;
    }
    .jewelry-gallery-heading {
      font-size: 1.8rem;
      margin-bottom: 25px;
    }
    .jewelry-gallery-overlay h3 {
      font-size: 1.2rem;
    }
    .jewelry-gallery-overlay p {
      font-size: 0.8rem;
    }
  }
{%- endstyle -%}

<div class="jewelry-gallery-{{ section.id }}">
  <div class="jewelry-gallery-container">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="jewelry-gallery-heading" style="text-align: {{ section.settings.heading_alignment }};">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="jewelry-gallery-grid">
      {%- for block in section.blocks -%}
        <div class="jewelry-gallery-item" {{ block.shopify_attributes }}>
          
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" style="display: block; width: 100%; height: 100%;">
          {%- endif -%}

          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}

          {%- if block.settings.title != blank or block.settings.subtitle != blank -%}
            <div class="jewelry-gallery-overlay">
              {%- if block.settings.title != blank -%}
                <h3>{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.subtitle != blank -%}
                <p>{{ block.settings.subtitle }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
          
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Jewelry Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collections"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Space between images",
      "default": 16
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Vertical images (4:5 ratio) work best for jewelry."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title Overlay",
          "default": "Diamond Rings"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle Overlay",
          "default": "View Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Jewelry Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}