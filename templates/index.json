      "blocks": {
        "template--21109129117976__e2e754bf-d47e-4ef9-8fd7-1ced7e029d74-quote-1": {
          "type": "quote",
          "settings": {
            "title": "",
            "author": "Anna M.",
            "info": "from Vogue",
            "rate": 5,
            "quote": "Embodying the feminine silhouettes, the activewear evokes an effortless elegance. Each design is a carefully considered piece, whether being squat-proof, booty-shaping or lingerie inspired"
          }
        },
        "template--21109129117976__e2e754bf-d47e-4ef9-8fd7-1ced7e029d74-quote-2": {
          "type": "quote",
          "settings": {
            "title": "",
            "author": "Eleanor S.",
            "info": "from heath",
            "rate": 5,
            "quote": "At the editorial office we just have to say, WOW!  The materials feels & fits amazingly. It is by far the best work out outfit, the textiles are very good, lasting and resistant. Very sexy!"
          }
        },
        "template--21109129117976__e2e754bf-d47e-4ef9-8fd7-1ced7e029d74-quote-3": {
          "type": "quote",
          "settings": {
            "title": "",
            "author": "Hanler O.",
            "info": "from Elle",
            "rate": 5,
            "quote": "This is a beautiful sports bra. Absolutely love the fit of this bra , it is so flattering and well supporting. I wear it as a bikini bra and always get asked where I got it from."
          }
        }
