    "bcb1cba3-80fc-49a2-a033-40cf0618e9c8": {
      "type": "faq-accordion",
      "blocks": {
        "template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-0": {
          "type": "faq",
          "settings": {
            "faq_title": "Materials",
            "faq_des": "<p>At our fine jewelry house, every piece is expertly crafted in solid 14K Yellow, Rose, or White Gold, with 18K Gold available upon request. We use only natural diamonds and genuine gemstones to create timeless jewelry designed to be cherished for years to come.</p><h3></h3>"
          }
        },
        "faq_UPAM8q": {
          "type": "faq",
          "settings": {
            "faq_title": "Product Lead Time",
            "faq_des": "<p>Most <strong>Auvera Craft</strong> jewelry is handcrafted to order. Our estimated production times are:</p><ul><li><strong>Rings &amp; Earrings:</strong> 1–2 weeks</li><li><strong>Bracelets &amp; Necklaces:</strong> 2–3 weeks</li><li><strong>Delivery:</strong> 7–10 business days after your order ships</li></ul><p>Estimated production times are also shown on each product page. If you have any questions, please contact the <strong>Auvera Craft Team</strong>.</p>"
          }
        },
        "template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-1": {
          "type": "faq",
          "settings": {
            "faq_title": "Custom Items & Jewelry Revamp",
            "faq_des": "<p>Looking to create a one-of-a-kind piece or redesign a treasured jewelry item? Our team would be delighted to bring your vision to life with personalized craftsmanship and timeless design. For custom inquiries or jewelry revamps, please contact us at Auvera Support Team</p><h3></h3>"
          }
        },
        "template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-2": {
          "type": "faq",
          "settings": {
            "faq_title": "Sizing",
            "faq_des": "<p>Need help finding your perfect fit? We recommend printing our size guide and following the instructions carefully to ensure the most accurate size selection.<br/><a href=\"/pages/size-guide\" target=\"_blank\" title=\"Size Guide\">Size Guide</a></p><p></p>"
          }
        },
        "faq_x94NtC": {
          "type": "faq",
          "settings": {
            "faq_title": "Repairs and Resizing",
            "faq_des": "<p>We are pleased to offer complimentary repairs within 150 days of purchase for eligible items. After this period, repair and shipping fees will apply, with repair services typically starting at $30 plus shipping, depending on the design.</p><p>Most rings can be resized; however, certain styles such as eternity bands cannot be adjusted. Ring resizing services generally begin at $60 plus shipping and vary based on the piece.</p><p>Please note that bangles and eternity bands are not eligible for resizing.</p><p>Any repairs or alterations performed by third-party jewelers will void the warranty on your piece, and we cannot be responsible for work completed outside of our atelier.</p><p>We reserve the right to deny repair or replacement requests for items showing signs of intentional damage or misuse.</p><p>For repair or resizing inquiries, please email your order number along with the requested adjustment details to Auvera Support team</p>"
          }
        },
        "faq_EBxPV6": {
          "type": "faq",
          "settings": {
            "faq_title": "Discounts and Promotions",
            "faq_des": "<p>Please note that promotional offers and discount codes cannot be combined. Only one promotion or discount may be applied per order. Gift Cards are excluded from all discounts and promotional offers.</p><h3></h3>"
          }
        },
        "faq_QqjH4L": {
          "type": "faq",
          "settings": {
            "faq_title": "Lifetime Warranty Policy",
            "faq_des": "<p>Every <strong>Auvera Craft</strong> piece is protected by our <strong>Limited Lifetime Craftsmanship Warranty</strong>, which covers <strong>manufacturing defects</strong>. The warranty does <strong>not</strong> cover <strong>accidental damage</strong>, <strong>ring resizing</strong>, or <strong>shipping costs</strong>. For complete details, please read our <a href=\"/pages/lifetime-warranty-policy\"><strong>Warranty &amp; Repair Policy</strong></a>.</p>"
          }
        }
      },
